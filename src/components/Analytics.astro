---
// Privacy-friendly analytics. Renders nothing unless enabled in src/consts.ts.
import { ANALYTICS } from '../consts';
const on = ANALYTICS.enabled && ANALYTICS.site;
---
{on && ANALYTICS.provider === 'plausible' && (
  <script is:inline defer data-domain={ANALYTICS.site} src="https://plausible.io/js/script.js"></script>
)}
{on && ANALYTICS.provider === 'goatcounter' && (
  <script is:inline data-goatcounter={`https://${ANALYTICS.site}.goatcounter.com/count`} async src="//gc.zgo.at/count.js"></script>
)}
