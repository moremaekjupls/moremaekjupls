---
// Contact form via Formspree (no backend). Hidden until an endpoint is set in src/consts.ts.
import { useTranslations, type Lang } from '../i18n/ui';
import { CONTACT } from '../consts';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const endpoint = CONTACT.formspreeEndpoint;
---
{endpoint ? (
  <form class="contact-form card" action={endpoint} method="POST">
    <h2 class="heading" style="margin-bottom:18px;">{t('contact.title')}</h2>
    <p class="muted" style="margin-bottom:24px;">{t('contact.sub')}</p>
    <div class="field">
      <label for="cf-name">{t('contact.name')}</label>
      <input id="cf-name" name="name" type="text" required autocomplete="name" />
    </div>
    <div class="field">
      <label for="cf-email">{t('contact.email')}</label>
      <input id="cf-email" name="email" type="email" required autocomplete="email" />
    </div>
    <div class="field">
      <label for="cf-msg">{t('contact.message')}</label>
      <textarea id="cf-msg" name="message" rows="5" required></textarea>
    </div>
    <button class="btn btn-primary" type="submit">{t('contact.send')}</button>
  </form>
) : null}
