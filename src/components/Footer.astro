---
import { useTranslations, localizeUrl, type Lang } from '../i18n/ui';
import { SOCIALS } from '../consts';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const socials = [
  { key: 'github', label: 'GitHub', href: SOCIALS.github, path: 'M12 1.5a10.5 10.5 0 0 0-3.32 20.46c.52.1.71-.23.71-.5v-1.9c-2.9.63-3.52-1.24-3.52-1.24-.48-1.2-1.16-1.52-1.16-1.52-.95-.65.07-.64.07-.64 1.05.08 1.6 1.08 1.6 1.08.94 1.6 2.46 1.14 3.06.87.1-.68.37-1.14.66-1.4-2.32-.26-4.76-1.16-4.76-5.16 0-1.14.41-2.07 1.07-2.8-.1-.26-.46-1.32.1-2.74 0 0 .88-.28 2.88 1.07a9.9 9.9 0 0 1 5.24 0c2-1.35 2.87-1.07 2.87-1.07.57 1.42.21 2.48.1 2.74.67.73 1.07 1.66 1.07 2.8 0 4.01-2.45 4.9-4.78 5.16.38.32.71.95.71 1.92v2.85c0 .28.19.61.72.5A10.5 10.5 0 0 0 12 1.5Z' },
  { key: 'x', label: 'X', href: SOCIALS.x, path: 'M17.5 3h2.9l-6.35 7.26L21.5 21h-5.86l-4.6-6.02L5.8 21H2.9l6.8-7.77L2.5 3h6l4.16 5.5L17.5 3Zm-1.02 16.2h1.6L7.6 4.72H5.88l10.6 14.48Z' },
  { key: 'linkedin', label: 'LinkedIn', href: SOCIALS.linkedin, path: 'M4.98 3.5A2.5 2.5 0 1 1 5 8.5a2.5 2.5 0 0 1-.02-5ZM3 9.25h3.96V21H3V9.25ZM9.25 9.25H13v1.6h.05c.52-.94 1.8-1.94 3.7-1.94 3.96 0 4.7 2.5 4.7 5.75V21h-3.96v-5.2c0-1.24-.02-2.84-1.73-2.84-1.74 0-2 1.35-2 2.75V21H9.25V9.25Z' },
  { key: 'email', label: 'Email', href: SOCIALS.email, path: 'M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm9 7.5L20 7H4l8 5.5ZM4 9.1V18h16V9.1l-8 5.5-8-5.5Z' },
];
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a class="logo" href={localizeUrl('/', lang)} style="margin-bottom:12px;">
        <svg class="mark" width="20" height="20" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <path d="M11 1.5 20.5 7v8L11 20.5 1.5 15V7L11 1.5Z" stroke="currentColor" stroke-width="1.4"/>
          <path d="M1.8 7 11 12l9.2-5M11 12v8.3" stroke="currentColor" stroke-width="1.4"/>
        </svg>
        <span>Khondamir Begmatov</span>
      </a>
      <p class="footer-copy" style="margin-top:10px;">{t('footer.tagline')}</p>
      <p class="footer-copy" style="margin-top:6px;">© {year} Khondamir Begmatov. {t('footer.rights')}</p>
    </div>
    <div>
      <p class="caption" style="text-transform:uppercase;letter-spacing:0.14em;margin-bottom:14px;">{t('footer.connect')}</p>
      <ul class="footer-socials">
        {socials.map((s) => (
          <li>
            <a href={s.href} target={s.key === 'email' ? undefined : '_blank'} rel="noopener noreferrer" aria-label={s.label}>
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={s.path}/></svg>
              <span>{s.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>
