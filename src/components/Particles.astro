---
// Particle constellation — the brand visual from DESIGN.md.
// Thousands of 2–6px geometric shapes clustering into an organic form
// on the pure-black void. Colors drawn from the palette.
// Respects prefers-reduced-motion (renders a static field).
interface Props {
  variant?: 'brain' | 'sphere' | 'spore';
  density?: number; // 0.5–1.5 multiplier
  class?: string;
}
const { variant = 'brain', density = 1, class: className = '' } = Astro.props;
---
<canvas
  class={`particles js-particles ${className}`}
  data-variant={variant}
  data-density={density}
  aria-hidden="true"
></canvas>

<script>
  type Shape = 'tri' | 'circle' | 'diamond' | 'square';
  interface P { bx: number; by: number; x: number; y: number; r: number; shape: Shape; color: string; tw: number; phase: number; drift: number; }

  const PALETTE = ['#8052ff', '#8052ff', '#ffffff', '#ffffff', '#bdbdbd', '#ffb829', '#15846e'];
  const SHAPES: Shape[] = ['tri', 'circle', 'diamond', 'square'];

  function rand(a: number, b: number) { return a + Math.random() * (b - a); }
  function gauss() { // ~N(0,1) via Box-Muller
    let u = 0, v = 0;
    while (u === 0) u = Math.random();
    while (v === 0) v = Math.random();
    return Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
  }

  function build(w: number, h: number, variant: string, density: number): P[] {
    const cx = w * 0.5, cy = h * 0.5;
    const base = Math.round((w * h) / 950 * density);
    const count = Math.max(120, Math.min(900, base));
    const pts: P[] = [];
    const spreadX = w * 0.30, spreadY = h * 0.32;

    for (let i = 0; i < count; i++) {
      const edge = Math.random() < 0.22; // sparse drift at edges
      let x: number, y: number;
      if (edge) {
        x = rand(0, w); y = rand(0, h);
      } else {
        let gx = gauss(), gy = gauss();
        if (variant === 'spore') { // ring-ish
          const ang = Math.random() * Math.PI * 2;
          const rad = 0.6 + Math.abs(gauss()) * 0.25;
          gx = Math.cos(ang) * rad * 1.6; gy = Math.sin(ang) * rad * 1.6;
        } else if (variant === 'sphere') {
          gx *= 0.85; gy *= 0.85;
        } else { // brain — two lobes
          const lobe = Math.random() < 0.5 ? -1 : 1;
          gx = gx * 0.8 + lobe * 0.7;
        }
        x = cx + gx * spreadX;
        y = cy + gy * spreadY;
      }
      const r = rand(1, 3);
      pts.push({
        bx: x, by: y, x, y, r,
        shape: SHAPES[(Math.random() * SHAPES.length) | 0],
        color: PALETTE[(Math.random() * PALETTE.length) | 0],
        tw: rand(0.3, 1), phase: Math.random() * Math.PI * 2, drift: rand(0.2, 0.9),
      });
    }
    return pts;
  }

  function draw(ctx: CanvasRenderingContext2D, p: P, t: number, reduce: boolean) {
    const tw = reduce ? 0.8 : 0.55 + 0.45 * Math.abs(Math.sin(t * 0.0009 + p.phase));
    const ox = reduce ? 0 : Math.sin(t * 0.0004 + p.phase) * p.drift;
    const oy = reduce ? 0 : Math.cos(t * 0.0005 + p.phase) * p.drift;
    const x = p.bx + ox, y = p.by + oy, r = p.r;
    ctx.globalAlpha = p.tw * tw;
    ctx.fillStyle = p.color;
    ctx.strokeStyle = p.color;
    ctx.beginPath();
    switch (p.shape) {
      case 'circle': ctx.arc(x, y, r, 0, Math.PI * 2); ctx.fill(); break;
      case 'square': ctx.fillRect(x - r, y - r, r * 2, r * 2); break;
      case 'diamond':
        ctx.moveTo(x, y - r); ctx.lineTo(x + r, y); ctx.lineTo(x, y + r); ctx.lineTo(x - r, y); ctx.closePath(); ctx.fill(); break;
      case 'tri':
        ctx.moveTo(x, y - r); ctx.lineTo(x + r, y + r); ctx.lineTo(x - r, y + r); ctx.closePath(); ctx.fill(); break;
    }
  }

  function initCanvas(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const variant = canvas.dataset.variant || 'brain';
    const density = parseFloat(canvas.dataset.density || '1');
    let pts: P[] = [];
    let w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);
    let raf = 0;

    function resize() {
      const rect = canvas.getBoundingClientRect();
      w = Math.max(1, rect.width); h = Math.max(1, rect.height);
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      pts = build(w, h, variant, density);
    }

    function frame(t: number) {
      ctx!.clearRect(0, 0, w, h);
      for (const p of pts) draw(ctx!, p, t, reduce);
      ctx!.globalAlpha = 1;
      if (!reduce) raf = requestAnimationFrame(frame);
    }

    resize();
    let rt: number | undefined;
    window.addEventListener('resize', () => {
      window.clearTimeout(rt);
      rt = window.setTimeout(() => { cancelAnimationFrame(raf); resize(); if (reduce) frame(0); else raf = requestAnimationFrame(frame); }, 150);
    });

    if (reduce) frame(0);
    else {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) { if (!raf) raf = requestAnimationFrame(frame); }
          else { cancelAnimationFrame(raf); raf = 0; }
        }
      }, { threshold: 0 });
      io.observe(canvas);
    }
  }

  function boot() {
    document.querySelectorAll<HTMLCanvasElement>('canvas.js-particles').forEach((c) => {
      if (!(c as any)._init) { (c as any)._init = true; initCanvas(c); }
    });
  }
  if (document.readyState !== 'loading') boot();
  else document.addEventListener('DOMContentLoaded', boot);
  document.addEventListener('astro:page-load', boot);
</script>
